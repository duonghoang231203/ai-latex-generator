{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AI LaTeX Generator — Evaluation Test Cases",
  "type": "object",
  "required": ["version", "cases"],
  "properties": {
    "version": { "type": "string" },
    "source": { "type": "string" },
    "note": { "type": "string" },
    "engineDefault": { "type": "string" },
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "scope", "input", "expect", "pass", "fail"],
        "properties": {
          "id": { "type": "string", "pattern": "^TC-[0-9]{2}$" },
          "title": { "type": "string" },
          "scope": { "type": "string", "enum": ["mvp", "v1", "v2"] },
          "docType": { "type": "string", "enum": ["article", "report"] },
          "input": {
            "type": "object",
            "required": ["kind"],
            "properties": {
              "kind": { "type": "string", "enum": ["prompt", "file", "image", "project"] },
              "prompt": { "type": "string" },
              "path": { "type": "string" },
              "description": { "type": "string" }
            }
          },
          "expect": { "type": "object", "description": "Ràng buộc kiểm tự động (parse/compile/contains...)." },
          "pass": { "type": "string" },
          "fail": { "type": "string" }
        }
      }
    }
  }
}
