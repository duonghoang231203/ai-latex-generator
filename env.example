# AI Configuration
AI_PROVIDER=mock # Options: 'mock', 'anthropic', 'openai'
AI_API_KEY=your_api_key_here
AI_MODEL= # Leave empty to use default model for the provider
AI_BASE_URL= # Leave empty for default URL. Use for custom endpoints like Groq/OpenRouter
AI_TEMPERATURE=0.2
AI_MAX_TOKENS=8192

# Compile Service
COMPILE_SERVICE_URL=http://localhost:8080

# Limits & Timeout
MAX_REPAIR_ATTEMPTS=3
MAX_INPUT_CHARS=20000
MAX_SOURCE_FILES=10
MAX_SOURCE_CHARS=100000
REQUEST_TIMEOUT_MS=60000
RATE_LIMIT_PER_MINUTE=10
MAX_UPLOAD_BYTES=15728640 # 15MB

# Storage
DATA_DIR=.data

# OCR Configuration
OCR_ENABLED=true
OCR_LANGS=vie+eng
# TESSERACT_CACHE_DIR= # Optional, defaults to OS tmpdir if not set

# Deployment (Docker/Caddy)
# SITE_ADDRESS=yourdomain.com # Set this without scheme to automatically enable Let's Encrypt TLS in production
